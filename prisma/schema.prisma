generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt()

  books Book[]
}

model Book {
  id          String   @id @default(uuid())
  title       String
  author      String
  description String?
  coverUrl    String?
  coverKey    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt()

  userId String
  user   User   @relation(fields: [userId], references: [id])
}
